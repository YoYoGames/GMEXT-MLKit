{
  "$schema": "./extgen.schema.json",
  "input": "spec.gmidl",
  "root": "./",
  "gamemaker": {
    "wrappers": {
      "outputFile": "../../../scripts/GMMLKit_API/GMMLKit_API.gml"
    },
    "extension": {
      "mode": "patch",
      "outputFile": "../../../extensions/GMMLKit/GMMLKit.yy"
    },
    "injectors": { }
  },
  "targets": {
    "windows":{},
    "macos":{},
    "linux":{},
    "android":{
      "mode": "java"
    },
    "ios":{
      "mode": "objc"
    }
  },
  "extras": {
    "docs": { 
      "outputFile": "../../../../../docs/extgen_docs.js"
    }
  }
}